tests {
  test("Bulk create response structure", function() {
    expect(res.status).to.equal(201);
    expect(res.body).to.have.property("success");
    expect(res.body).to.have.property("failure");
    expect(res.body.success).to.be.a("number");
    expect(res.body.failure).to.be.a("number");
  });
}
