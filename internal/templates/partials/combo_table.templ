package partials

import "github.com/datdev2409/lab-admin-go/internal/models"

templ ComboTable(combos []*models.Combo) {
	<table class="table table-bordered">
		<thead>
			<tr>
				<th style="max-width: 130px">Tên gói xét nghiệm</th>
				<th>Xét nghiệm</th>
				<th style="width: 130px">Thao tác</th>
			</tr>
		</thead>
		<tbody>
			for _, combo := range combos {
				@ComboRow(combo)
			}
		</tbody>
	</table>
	@ComboTableScript()
}
