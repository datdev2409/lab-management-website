package partials

import "github.com/datdev2409/lab-admin-go/internal/models"

templ TestTable(tests []*models.Test, page string, outOfBand bool) {
	<div
		id="test-table"
		if outOfBand {
			hx-swap-oob="true"
		}
	>
		<table class="table table-bordered table-hover">
			@TestTableHeader(page)
			<tbody>
				for _, test := range tests {
					@TestRow(test, page)
				}
			</tbody>
		</table>
	</div>
}
