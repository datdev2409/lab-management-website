package partials

import (
	"encoding/json"
	"github.com/datdev2409/lab-admin-go/internal/models"
)

templ RecordTestAutocomplete(tests []*models.Test) {
	<div x-show="open" @click.outside="open=false" id="test-autocomplete" class="shadow bordered position-absolute autocomplete">
		for _, test := range tests {
			{{ b, _ := json.Marshal(test) }}
			<div class="autocomplete-option" @click={ "open=false;addTest(JSON.parse('" + string(b) + "'))" }>
				{ test.Name }
			</div>
		}
	</div>
}
