package partials

templ TrackingTestTable() {
	<table id="tracking-test-table" class="table table-bordered mb-0">
		<thead class="position-sticky top-0">
			<tr>
				<th scope="col">Tên xét nghiệm</th>
				<th style="width: 200px" scope="col">GT bình thường</th>
				<th style="width: 140px" scope="col">Đơn vị</th>
			</tr>
		</thead>
		<tbody>
			<template x-sort x-for="test in tests" x-key="test.id">
				<tr x-sort:item>
					<td x-text="test.name"></td>
					<td style="width: 200px" x-text="test.normal_value"></td>
					<td style="width: 140px" x-text="test.unit"></td>
				</tr>
			</template>
			<template x-for="i in number_of_empty_tests" x-key="i">
				<tr>
					<td>
						@RecordTestSelect()
					</td>
					<td style="width: 200px"></td>
					<td style="width: 140px"></td>
				</tr>
			</template>
		</tbody>
	</table>
	<button type="button" @click="number_of_empty_tests += 1">+</button>
}
