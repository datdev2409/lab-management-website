package partials

import "github.com/datdev2409/lab-admin-go/internal/models"

templ TrackingTestTable(tests []*models.TestInfo) {
	<table id="tracking-test-table" class="table table-bordered mb-0">
		<thead class="position-sticky top-0">
			<tr>
				<th scope="col"></th>
				<th>Tên xét nghiệm</th>
				<th style="width: 200px" scope="col">GT bình thường</th>
				<th style="width: 140px" scope="col">Đơn vị</th>
			</tr>
		</thead>
		<tbody x-sort>
			for _, test := range tests {
				<tr>
					<td x-sort:item>-</td>
					<td>{ test.Name }</td>
					<td style="width: 200px">{ test.NormalValue }</td>
					<td style="width: 140px">{ test.Unit }</td>
				</tr>
			}
		</tbody>
	</table>
}
