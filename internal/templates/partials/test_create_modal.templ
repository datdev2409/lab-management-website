package partials

templ TestCreateModal() {
	<div class="modal fade" id="test-create-modal" tabindex="-1">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Thêm xét nghiệm</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body" x-data="createTestForm()">
					<form @submit.prevent="createTest" id="test_create_form">
						<div class="alert alert-danger p-2" x-show="error" x-text="error" x-cloak></div>
						@InputField("Tên xét nghiệm", "test_name", "form.name", "", templ.Attributes{"type": "text", "required": "true"})
						@InputField("Khoảng bình thường", "test_normal_value", "form.normal_value", "", templ.Attributes{"type": "text", "required": "true"})
						@InputField("Đơn vị", "test_unit", "form.unit", "", templ.Attributes{"type": "text", "required": "true"})
						<div class="row">
							<div class="col">
								@InputField("Cận dưới", "test_lower_bound", "form.lower_bound", "", templ.Attributes{"type": "number", "step": "0.01", "required": "true"})
							</div>
							<div class="col">
								@InputField("Cận trên", "test_upper_bound", "form.upper_bound", "", templ.Attributes{"type": "number", "step": "0.01", "required": "true"})
							</div>
						</div>
						@InputField("Giá tiền", "test_price", "form.price", "", templ.Attributes{"type": "number", "required": "true"})
						<button style="float: right;" type="submit" class="btn btn-primary" x-bind:disabled="loading">
							<span x-show="loading">Đang tạo...</span>
							<span x-show="!loading">Thêm xét nghiệm</span>
						</button>
					</form>
					<script>
					function createTestForm() {
						return {
							form: { 
								name: '', 
								normal_value: '', 
								unit: '', 
								lower_bound: '', 
								upper_bound: '', 
								price: '' 
							},
							loading: false,
							error: '',
							async createTest() {
								this.loading = true;
								this.error = '';
								try {
									const res = await fetch('/api/v1/tests', {
										method: 'POST',
										headers: { 'Content-Type': 'application/json' },
										body: JSON.stringify(this.form)
									});
									this.loading = false;
									if (res.ok) {
										window.location.href = '/danh-muc-xet-nghiem?noti_code=create_test_success&noti_type=success';
									} else {
										const data = await res.json();
										this.error = data.error || 'Có lỗi xảy ra';
									}
								} catch (e) {
									this.loading = false;
									this.error = 'Có lỗi xảy ra';
								}
							}
						}
					}
					</script>
				</div>
			</div>
		</div>
	</div>
}
