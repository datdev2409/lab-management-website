package partials

templ TestCreateModal() {
	<div class="modal fade" id="test-create-modal" tabindex="-1">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Thêm xét nghiệm</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body" x-data="createTestForm()">
					<form @submit.prevent="createTest" id="test_create_form">
						<div class="alert alert-danger p-2" x-show="error" x-html="error" x-cloak></div>
						@InputField("Tên xét nghiệm", "test_name", "form.name", "", templ.Attributes{"type": "text", "required": "true"})
						@InputField("Khoảng bình thường", "test_normal_value", "form.normal_value", "", templ.Attributes{"type": "text", "required": "true"})
						@InputField("Đơn vị", "test_unit", "form.unit", "", templ.Attributes{"type": "text", "required": "true"})
						<div class="row">
							<div class="col">
								@InputField("Cận dưới", "test_lower_bound", "form.lower_bound", "", templ.Attributes{"type": "number", "step": "0.001"})
							</div>
							<div class="col">
								@InputField("Cận trên", "test_upper_bound", "form.upper_bound", "", templ.Attributes{"type": "number", "step": "0.001"})
							</div>
						</div>
						@InputField("Giá tiền", "test_price", "form.price", "", templ.Attributes{"type": "number", "required": "true"})
						<button style="float: right;" type="submit" class="btn btn-primary" x-bind:disabled="loading">
							<span x-show="loading">Đang tạo...</span>
							<span x-show="!loading">Thêm xét nghiệm</span>
						</button>
					</form>
					<script>
					function createTestForm() {
						return {
							form: { name: '', normal_value: '', unit: '', lower_bound: '', upper_bound: '', price: '' },
							error: '',
							loading: false,
							async createTest() {
								this.loading = true
								const requestBody = this.validateRequestData(this.form)
								await sendAPIRequestWithErrorHandler({method: "POST", url: "/api/v1/tests", body: requestBody, onSuccess: (data) => {
									window.location.href = "/danh-muc-xet-nghiem?noti_code=test_create_success"
									showCustomNotification("Thêm xét nghiệm thành công", "success");
								}, onError: ({error, requestId}) => {
									// this.error = error.error || 'Đã có lỗi xảy ra. Vui lòng thử lại hoặc liên hệ với quản trị viên.';
									this.error = `
										Lỗi: ${error || 'Đã có lỗi xảy ra. Vui lòng thử lại hoặc liên hệ với quản trị viên.'}<br>
										Mã yêu cầu: ${requestId}
									`
								}});
								this.loading = false
							},

							validateRequestData(data) {
								let { price, lower_bound, upper_bound } = data;

								// Convert to appropriate number types
								price = parseInt(price);
								lower_bound = parseFloat(lower_bound);
								upper_bound = parseFloat(upper_bound);

								// Validate number parsing
								if (isNaN(price) || price <= 0) {
									this.error = 'Giá tiền phải là số dương.';
									return null;
								}

								// Check if bounds are provided and valid
								if (lower_bound && upper_bound) {
									if (isNaN(lower_bound) || isNaN(upper_bound)) {
										this.error = 'Các cận phải là số hợp lệ.';
										return null;
									}

									if (lower_bound >= upper_bound) {
										this.error = 'Cận dưới phải nhỏ hơn cận trên.';
										return null;
									}
								}

								// Return validated data
								return JSON.stringify({
									...data,
									price,
									lower_bound: lower_bound || null,
									upper_bound: upper_bound || null
								});
							}
						}
					}
					</script>
				</div>
			</div>
		</div>
	</div>
}
