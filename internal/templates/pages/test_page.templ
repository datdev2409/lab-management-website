package pages

import (
	"github.com/datdev2409/lab-admin-go/internal/models"
	"github.com/datdev2409/lab-admin-go/internal/templates/partials"
)

templ TestPage(tests []*models.Test, message string) {
	{{
		var testPageProps = models.PageProps{
			Title: "Danh mục xét nghiệm",
			Path:  "/danh-muc-xet-nghiem",
		}
	}}
	@partials.Base(testPageProps) {
		<div class="d-flex align-items-center justify-content-between">
			<h3 class="pt-3">Danh mục xét nghiệm</h3>
			<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#test-create-modal">Thêm xét nghiệm</button>
		</div>
		@partials.TestCreateModal()
		<div class="mb-2 d-flex align-items-center">
			<input style="max-width: 200px;" class="form-control" name="test_name" id="test-search"/>
			<button type="button" class="ms-2 btn btn-primary" hx-get="/api/tests" hx-target="#test-table" hx-include="#test-search">Tìm</button>
		</div>
		@partials.TestTable(tests, "test-page", false)
	}
}
