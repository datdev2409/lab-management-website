package pages

import "github.com/datdev2409/lab-admin-go/internal/templates/partials"

templ TestPage() {
	@partials.Base() {
		<div class="d-flex align-items-center justify-content-between">
			<h3 class="pt-3">Danh mục xét nghiệm</h3>
			<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#test-create-modal">Thêm xét nghiệm</button>
		</div>
		@partials.TestCreateModal()
		@partials.TestTable()
	}
}
