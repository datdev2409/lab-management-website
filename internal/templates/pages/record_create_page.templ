package pages

import "github.com/datdev2409/lab-admin-go/internal/templates/partials"

templ RecordCreatePage() {
	@partials.SidebarTemplate() {
		<div class="d-flex align-items-center justify-content-between">
			<h3 class="pt-3">Tạo phiếu xét nghiệm mới</h3>
			@partials.PatientCreateModal()
		</div>
		<div class="my-3">
			@partials.RecordCreateForm("")
		</div>
	}
}
